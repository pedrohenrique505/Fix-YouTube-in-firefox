{
  "manifest_version": 2,
  "name": "Fix Youtube",
  "version": "1.0",
  "browser_specific_settings": {
    "gecko": {
      "id": "fix-youtube-addon@mozilla.org",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "description": "Bloqueia YouTube Shorts e expande a fila de vídeos para 5 itens",
  "permissions": [
    "https://www.youtube.com/*",
    "https://m.youtube.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.youtube.com/*",
        "https://m.youtube.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "48": "logo-48.png",
    "128": "logo-128.png"
  }
}